# FRIDAY AI Brain - Environment Configuration
# Copy this file to .env and fill in your actual values

# ============================================================================
# OpenAI Configuration (Default LLM)
# ============================================================================
OPENAI_API_KEY=sk-your-api-key-here

# Optional: Specify OpenAI model
# Defaults to: gpt-4 or gpt-3.5-turbo
# OPENAI_MODEL=gpt-4

# ============================================================================
# Ollama Configuration (Local LLM Alternative)
# ============================================================================
# Uncomment these if using Ollama instead of OpenAI
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=neural-chat

# ============================================================================
# Anthropic Claude Configuration (Alternative)
# ============================================================================
# Uncomment if using Anthropic Claude
# ANTHROPIC_API_KEY=your-claude-api-key-here
# ANTHROPIC_MODEL=claude-3-opus

# ============================================================================
# FastAPI Configuration
# ============================================================================
# Host and port for the API server
API_HOST=0.0.0.0
API_PORT=8000

# Debug mode (set to False in production)
DEBUG=True

# ============================================================================
# Logging Configuration
# ============================================================================
LOG_LEVEL=INFO

# ============================================================================
# CrewAI Configuration
# ============================================================================
# Enable verbose output from agents
CREW_VERBOSE=True
